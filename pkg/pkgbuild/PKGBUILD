# Maintainer: Yulong Ming <i@myl.moe>
pkgname=doubao-voice-input-electron-bin
_pkgname=doubao-voice-input-electron
pkgver=0.1.0
pkgrel=1
pkgdesc='Real-time speech-to-text desktop app using Bytedance Seed ASR'
arch=('x86_64')
url="https://github.com/myl/${_pkgname}"
license=('MIT')
depends=('gtk3' 'nss' 'alsa-lib' 'libxss' 'libxtst')
optdepends=('ydotool: keyboard simulation on Wayland')
provides=("${_pkgname}")
conflicts=("${_pkgname}")
options=('!strip' '!debug')
source=("${_pkgname}_${pkgver}_amd64.deb::${url}/releases/download/v${pkgver}/${_pkgname}_${pkgver}_amd64.deb"
        "${_pkgname}.service")
sha256sums=('SKIP'
            'bcd3cb66c93fe888ac141f1156025b89d96f34284f4142932598d0d37af29e79')

prepare() {
    cd "${srcdir}"
    ar x "${_pkgname}_${pkgver}_amd64.deb"
}

package() {
    cd "${srcdir}"

    # Extract deb data
    tar xf data.tar.* -C "${pkgdir}/"

    # Install systemd user service
    install -Dm644 "${srcdir}/${_pkgname}.service" \
        "${pkgdir}/usr/lib/systemd/user/${_pkgname}.service"
}
